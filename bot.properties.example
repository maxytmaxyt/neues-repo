# ─────────────────────────────────────────────────────────────────────────────
# Discord TempChannel Bot – Beispiel-Konfiguration
# Kopiere diese Datei als "bot.properties" in dasselbe Verzeichnis wie bot.jar
# ─────────────────────────────────────────────────────────────────────────────

# Bot-Token (von https://discord.com/developers/applications)
token=YOUR_BOT_TOKEN_HERE

# ID des Discord-Servers
guild.id=123456789012345678

# Textkanal, in dem die Verwaltungs-Panels erscheinen
panel.channel.id=123456789012345678

# Kategorien für temporäre Sprachkanäle (Komma-getrennt, in Prioritätsreihenfolge)
# Wenn die erste Kategorie voll ist, wird automatisch auf die nächste ausgewichen
categories=123456789012345678,987654321098765432

# Maximale Kanalanzahl pro Kategorie, bevor zur nächsten gewechselt wird
# Discord-Limit: 50 – Standard hier: 45 (Sicherheitspuffer)
category.max.channels=45

# Optional: Rollen-IDs, die auch in gesperrte Kanäle joinen dürfen (Komma-getrennt)
# Leer lassen, wenn nicht benötigt
# bypass.role.ids=111111111111111111,222222222222222222
